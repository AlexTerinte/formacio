<?xml version="1.0" encoding="UTF-8"?>

<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Album Cards"
          sling:resourceType="cq/gui/components/authoring/dialog">

    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">

        <items jcr:primaryType="nt:unstructured">
            <cards
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                fieldLabel="Tarjetas"
                composite="{Boolean}true"
                name="./cards">

                <field
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container"
                    name="./cards">

                    <items jcr:primaryType="nt:unstructured">
                        <imageUrl
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                            fieldLabel="Imagen (ruta o URL)"
                            name="./imageUrl"
                            rootPath="/content/dam"
                            emptyText="/content/dam/myproject/images/placeholder.jpg"/>

                        <imageAlt
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldLabel="Texto alternativo (alt)"
                            name="./imageAlt"
                            emptyText="Describe la imagen para accesibilidad"/>

                        <description
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                            fieldLabel="Descripción de la tarjeta"
                            name="./description"
                            rows="3"
                            emptyText="Texto de soporte de la tarjeta…"/>

                        <viewLink
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                            fieldLabel="Enlace 'View'"
                            name="./viewLink"
                            rootPath="/content"/>

                        <editLink
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                            fieldLabel="Enlace 'Edit'"
                            name="./editLink"
                            rootPath="/content"/>

                        <readingTime
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                            fieldLabel="Tiempo de lectura (mins)"
                            name="./readingTime"
                            min="1"
                            step="1"
                            emptyText="9"/>
                    </items>
                </field>
            </cards>
        </items>
    </content>
</jcr:root>